<!DOCTYPE html>
<html>
<head>
    {{> header}}
    <title>Clients - Sakila</title>
</head>
<body>
    {{> menu}}
    <main class="container">
        <h1>Llista de Clients (Top 25)</h1>
        <div class="customers-list">
            {{#each customers}}
            <div class="customer-item">
                <h3>{{this.first_name}} {{this.last_name}}</h3>
                <p><strong>Últims lloguers:</strong></p>
                <p>{{#if this.rentals}}{{this.rentals}}{{else}}Sense lloguers recents{{/if}}</p>
                <hr>
            </div>
            {{/each}}
        </div>
    </main>
    {{> footer}}
</body>
</html>